# ── $SHELL Miner Configuration ────────────────────────────────────────────────
# Run `npx @openshell-cc/miner-cli setup` to configure interactively
# 挖矿默认只需要 SHELL_API_KEY；LLM_API_KEY 仅用于高级本地计算模式

# Oracle endpoint (production)
ORACLE_URL=https://oracle.openshell.cc

# ── Authentication ────────────────────────────────────────────────────────────

# $SHELL API Key (推荐) — 在 https://openshell.cc/dashboard 注册获取
SHELL_API_KEY=

# Solana Wallet (可选，已有钱包才需要)
# WALLET_PRIVATE_KEY=

# ── 高级本地模型（可选）────────────────────────────────────────────────────────
# 默认模式下，平台 AI 负责生成 payload，你无需配置第三方 API Key。
# 如果你希望处理高级 local_compute 任务，可选填自己的模型配置：
#   Anthropic  → console.anthropic.com   (推荐: claude-haiku-4-5)
#   OpenAI     → platform.openai.com     (推荐: gpt-4o-mini)
#   DeepSeek   → platform.deepseek.com   (最便宜: deepseek-chat)

# LLM_PROVIDER=anthropic
# LLM_API_KEY=
# LLM_MODEL=claude-haiku-4-5

# ── Mining Configuration ──────────────────────────────────────────────────────

# 执行模式:
#   sandbox_only  — 默认推荐：平台 AI 生成 payload，零第三方 API Key
#   auto          — 自动（有本地模型时同时接受 sandbox + local_compute）
#   local_only    — 仅本地计算任务（需要 LLM_API_KEY）
EXECUTION_MODE=sandbox_only

POLLING_INTERVAL_MS=5000
