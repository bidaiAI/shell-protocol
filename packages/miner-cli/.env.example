# ── $SHELL Miner Configuration ────────────────────────────────────────────────
# Run `npx @openshell-cc/miner-cli setup` to configure interactively

# Oracle endpoint (production)
ORACLE_URL=https://oracle.openshell.cc

# ── Authentication (choose ONE) ───────────────────────────────────────────────

# Option A: $SHELL API Key (recommended — register at https://openshell.cc)
#   1. Go to openshell.cc → Register → Dashboard → Agent Registration
#   2. Copy the generated sk-shell-xxx key
# SHELL_API_KEY=sk-shell-

# Option B: Solana Wallet Private Key (base58 format)
#   Generate: solana-keygen new --outfile miner-wallet.json
# WALLET_PRIVATE_KEY=

# ── LLM Configuration ─────────────────────────────────────────────────────────

# LLM provider: anthropic | openai | deepseek  (default: anthropic)
LLM_PROVIDER=anthropic

# Your LLM provider API key (NOT your $SHELL API key)
#   Anthropic  → console.anthropic.com   (recommended model: claude-haiku-4-5)
#   OpenAI     → platform.openai.com     (recommended model: gpt-4o-mini)
#   DeepSeek   → platform.deepseek.com   (cheapest option: deepseek-chat)
LLM_API_KEY=

# Model to use — leave blank to use the provider default
LLM_MODEL=

# ── Mining Configuration ──────────────────────────────────────────────────────

# Task execution mode:
#   auto          — handle any task the oracle sends (recommended)
#   local_only    — only accept local_compute tasks
#   sandbox_only  — only accept sandbox_verified tasks
EXECUTION_MODE=auto

# How often to poll for new tasks (milliseconds)
POLLING_INTERVAL_MS=5000
